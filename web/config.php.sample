<?php
// Copy this file to config.php and edit the values to match your local
// MariaDB / MySQL installation. config.php is loaded by db.php.

return [
    'host'     => '127.0.0.1',
    'port'     => 3306,
    'user'     => 'root',
    'password' => 'YOUR_PASSWORD_HERE',
    'database' => 'stepbible',   // On many shared hosts this will be prefixed, e.g. 'youruser_stepbible' or 'biblewhe_stepbible'
    // Set to true to display PDO errors in the browser (handy during setup).
    'debug'    => true,

    // === Remote API mode (for development without local database) ===
    // When true, db.php will call the remote API instead of hitting MariaDB directly.
    // This lets other developers work on the UI by hitting your live site.
    'use_remote_api' => false,

    // Base URL of the API (without trailing slash). Example:
    // 'remote_api_base' => 'https://your-live-domain.com/bible',
    'remote_api_base' => '',

    // Shared secret used to sign trusted proxy note-write requests
    // (create/update/delete_verse_note) when use_remote_api=true.
    // Set the SAME value on both the caller and remote API servers.
    // Keep empty to disable proxy note writes.
    'remote_api_proxy_secret' => '',

    // === Shared site banner/header includes (optional) ===
    // Filesystem path to the biblewheel.com include directory containing
    // bwHeader.inc / bwBanner.php. When found, pages render with the full
    // site chrome instead of the minimal local header/banner.
    // NEVER copy that directory into this repo — it contains live DB
    // credentials (wp-config.php). On this workstation the canonical local
    // copy is the served one:
    // 'include_dir' => 'c:/Work/Resurrected/Bible Wheel Site/public_html/include',
    // Leave empty to auto-detect (../include next to the deployed app, or
    // ../../public_html/include from a dev checkout).
    'include_dir' => '',

    // === Optional phpBB integration for per-user features (notes, etc.) ===
    // Set this to the filesystem path to your phpBB root (with trailing slash).
    // If set and common.php exists, the notes page (and future user features)
    // will use phpBB's $user->data['user_id'] and username for ownership.
    // Example (adjust to your setup): '/home/user/public_html/forum/'
    // Leave empty for dev mode (falls back to PHP session with a demo user).
    'phpbb_path' => '',

    // Optional public URL prefix for your phpBB (used to load the real post editor JS/CSS
    // from your forum if you prefer to reference the live assets instead of the vendored copy
    // in web/js/phpbb-editor.js). Include trailing slash. Example: '/forum/' or 'https://forum.example.com/'.
    // If empty we use the local vendored editor (recommended for isolation).
    'phpbb_url' => '',

    // === Local dev demo users (used only when phpbb_path is empty) ===
    // Switch user by adding ?demo_user=<key> to any page URL in local dev.
    // Example: index.php?book=Gen&chapter=1&verse=1&demo_user=viewer
    'dev_demo_users' => [
        'admin'  => ['id' => 999999, 'name' => 'Demo Admin (local)',  'is_admin' => true],
        'viewer' => ['id' => 999998, 'name' => 'Demo Viewer (local)', 'is_admin' => false],
    ],
    'dev_demo_user_default' => 'admin',

    // === User badge in banner bar ===
    // Show a small "logged in as" badge in the top-right of the banner.
    // Automatically suppressed when phpbb_path is empty (dev fallback / demo user).
    // Set to true here to force it on even in dev mode.
    'show_user_badge' => false,

    // === Verse notes feature ===
    // Global switch for per-verse notes UI + API endpoints.
    // Set false to hide note controls and disable note API actions.
    'enable_notes' => true,

    // === Variant indicator bar ===
    // When true, word cells with variants show the clickable variant bar.
    // Set false to hide bars globally while keeping variant data available.
    'show_variant_indicator' => false,
];
